{
  "version": "0.2.0",
  "configurations": [

    // ── Flutter: Career Navigator ─────────────────────────────
    {
      "name": "📱 Career Navigator (Android)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "deviceId": "android"
    },
    {
      "name": "🪟 Career Navigator (Windows)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "deviceId": "windows"
    },
    {
      "name": "🌐 Career Navigator (Chrome)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "deviceId": "chrome"
    },
    {
      "name": "🚀 Career Navigator (Release)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "flutterMode": "release"
    },

    // ── Web App ───────────────────────────────────────────────
    {
      "name": "🕸️ Web App (Chrome localhost:8080)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:8080",
      "webRoot": "${workspaceFolder}"
    }
  ],

  // ── Compound: run both at the same time ───────────────────
  "compounds": [
    {
      "name": "🔥 Run Both (Mobile + Web)",
      "configurations": [
        "📱 Career Navigator (Android)",
        "🕸️ Web App (Chrome localhost:8080)"
      ],
      "stopAll": true
    }
  ]
}
