{
  "version": "0.2.0",
  "configurations": [

    // ── Flutter: Career Navigator ─────────────────────────────

    {
      "name": "📱 Android Phone (2409BRN2CA)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "deviceId": "2409BRN2CA"
    },
    {
      "name": "🤖 Android Emulator",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "deviceId": "emulator-5554"
    },
    {
      "name": "🪟 Windows Desktop",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "deviceId": "windows"
    },
    {
      "name": "🌐 Flutter Web (Chrome)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "deviceId": "chrome"
    },
    {
      "name": "🚀 Android Phone Release",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "flutterMode": "release",
      "deviceId": "2409BRN2CA"
    },

    // ── Web App (separate project) ────────────────────────────

    {
      "name": "🕸️ Web App (localhost:8080)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:8080",
      "webRoot": "${workspaceFolder}"
    }

  ],

  "compounds": [
    {
      "name": "🔥 Phone + Web App",
      "configurations": [
        "📱 Android Phone (2409BRN2CA)",
        "🕸️ Web App (localhost:8080)"
      ],
      "stopAll": true
    }
  ]
}
